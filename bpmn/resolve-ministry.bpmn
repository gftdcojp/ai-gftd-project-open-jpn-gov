<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="open-jpn-gov-resolve-ministry"
                  targetNamespace="https://gftd.ai/bpmn/open-jpn-gov">
  <bpmn:process id="resolveMinistry" name="Resolve Ministry DID" isExecutable="true">
    <bpmn:startEvent id="Start_Ref" name="Ministry reference received"/>
    <bpmn:sequenceFlow id="f1" sourceRef="Start_Ref" targetRef="Gateway_InputKind"/>

    <bpmn:exclusiveGateway id="Gateway_InputKind" name="code or DID?"/>
    <bpmn:sequenceFlow id="f2a" sourceRef="Gateway_InputKind" targetRef="Task_ByCode">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${inputKind == "code"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f2b" sourceRef="Gateway_InputKind" targetRef="Task_ByDid">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${inputKind == "did"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:serviceTask id="Task_ByCode" name="Lookup by code"
                      camunda:topic="ai.gftd.apps.openJpnGov.getMinistry"/>
    <bpmn:serviceTask id="Task_ByDid" name="Lookup by DID"
                      camunda:topic="ai.gftd.apps.openJpnGov.getMinistry"/>

    <bpmn:sequenceFlow id="f3a" sourceRef="Task_ByCode" targetRef="Task_Agencies"/>
    <bpmn:sequenceFlow id="f3b" sourceRef="Task_ByDid"  targetRef="Task_Agencies"/>

    <bpmn:serviceTask id="Task_Agencies" name="List child agencies"
                      camunda:topic="ai.gftd.apps.openJpnGov.listAgencies"/>
    <bpmn:sequenceFlow id="f4" sourceRef="Task_Agencies" targetRef="End_Resolved"/>

    <bpmn:endEvent id="End_Resolved" name="Ministry resolved"/>
  </bpmn:process>
</bpmn:definitions>
